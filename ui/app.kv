BoxLayout:
    orientation: 'vertical'
    padding: "20dp"
    spacing: "10dp"

    Label:
        text: "Paradise Trading App"
        font_size: "24sp"
        size_hint_y: 0.2

    Button:
        text: "Run Engine"
        size_hint_y: 0.1
        background_color: 0, 0.7, 0, 1
        on_press: app.start_engine()

    Widget:
        size_hint_y: 0.7
